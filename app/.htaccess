RewriteEngine on

# Legacy URL redirect. Old .html pages were migrated to .php, so any request
# for a .html file is permanently redirected (301) to the matching .php file.
# This keeps old bookmarks, inbound links, and search-engine results working,
# and tells search engines to update their index to the new .php URL.
RedirectMatch 301 ^(.*)\.html$ $1.php

# Front controller: every request is dispatched to index.php EXCEPT real
# static assets (assets/css, assets/js, assets/img), which are served
# directly — see src/routes.php. This also means pages/, api/, vendor/, and
# config.php are never reachable as raw files: a direct hit on any of them
# isn't a registered route, so the front controller answers with a plain 404
# instead of executing or serving the file's contents.
#
# The REDIRECT_STATUS guard is essential on FastCGI hosts (e.g. easy-hebergement,
# php-cgi/FPM): once Apache has internally rewritten a request to index.php it
# sets REDIRECT_STATUS, so the rule does NOT match a second time. Without it,
# `RewriteRule ^ index.php` re-matches the rewritten index.php and loops until
# Apache aborts the request with 500 ("Request exceeded the limit of 10 internal
# redirects"). We intentionally keep the catch-all (rather than a !-f/!-d guard)
# so raw files under pages/, api/, src/, vendor/, and config.php stay unreachable.
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^ index.php [L]

# Cache policy for this site.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  # Vite's build output (see App\Assets) is content-hashed: a given
  # filename's bytes never change, only the filename does when the
  # content does. Safe to cache indefinitely instead of revalidating.
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Images change rarely; let them cache for a day to stay fast. Bump the file
# name (or clear this rule) if you ever need an image to update immediately.
<IfModule mod_expires.c>
  ExpiresActive On
  <FilesMatch "\.(jpg|jpeg|png|gif|svg|ico|webp)$">
    ExpiresDefault "access plus 1 day"
  </FilesMatch>
</IfModule>
