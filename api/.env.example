APP_NAME="Les Canetons API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Cost factor for bcrypt password hashing (the User model's 'hashed' cast).
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Database — MariaDB, the SAME database the old app uses (this project shares
# one connection; it does not get its own DB). DB_DATABASE/USERNAME/PASSWORD are
# server-owned and left blank here — each server fills its real values by hand
# in .env, the same operational pattern as the old app's config.php.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Auth: Sanctum SPA cookie session. localhost/127.0.0.1 are local-dev
# placeholders — the real per-server .env sets these to the site's domain.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# No queue/cache infrastructure beyond the database — this app does no
# background work; mail is sent inline (sync).
QUEUE_CONNECTION=sync
CACHE_STORE=database

# Mail (contact + signups notifications). The server sets its real SMTP
# host/credentials by hand; MAIL_MAILER=log just writes mail to the log locally.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@les-canetons.localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Shared secret for the token-gated POST /api/migrate endpoint. Left blank
# here — each server sets its own real value, like the old app's migrate.token.
MIGRATE_TOKEN=
