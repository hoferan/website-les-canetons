# ---------------------------------------------------------------------------
# QA / staging site (<qa-host>) — access control
# ---------------------------------------------------------------------------

# --- Keep search engines out (belt-and-suspenders; Basic Auth already blocks
#     crawlers, and index.html carries a noindex meta tag) --------------------
<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

# --- HTTP Basic Auth for the whole staging site ----------------------------
# NOTE: AuthUserFile needs an ABSOLUTE server path (host-specific). The real
#       path is injected from HTPASSWD_PATH (.env.qa) by build-overlays.mjs,
#       replacing the __HTPASSWD_PATH__ token below — see staging/README.md.
# NOTE: the referenced .htpasswd is git-ignored (it holds credentials) and must
#       be created/uploaded by hand — see staging/README.md.
AuthType Basic
AuthName "Les Canetons — QA (acces restreint)"
AuthUserFile "__HTPASSWD_PATH__"

# The server-side migration endpoint is triggered by CI over HTTPS and gated by
# its own secret token (see app/api/migrate.php); exclude it from Basic Auth so
# automated deploys can reach it. Everything else still requires a valid user.
# Uses `Require expr` (mod_authz_core, same module as Require valid-user) rather
# than SetEnvIf, to avoid depending on mod_setenvif in .htaccess.
<RequireAny>
    Require expr "%{REQUEST_URI} =~ m#^/api/migrate(\?|$)#"
    Require valid-user
</RequireAny>

# --- Never serve the auth/control files themselves -------------------------
<FilesMatch "^\.(htaccess|htpasswd)$">
    Require all denied
</FilesMatch>
