# secrets & local-only
config.php
.env
/.env.*
!/.env.example
.superpowers
.tmp
public

# HTTP Basic Auth credential files (hashed, but still secrets — brute-forcible
# offline; usernames exposed). The .htaccess that references them IS tracked.
# See staging/README.md for how to (re)generate these.
.htpasswd

# real prod data — never commit (use the synthetic Docker seed instead)
*.dump.sql
prod-*.sql

# dependencies (dev-only tooling; never deployed)
/node_modules/
/vendor/

# Persistent Composer download cache reused across builds (tools/build.mjs)
/.composer-cache/

# Laravel API (api/) — dependencies & generated runtime artifacts. api/ ships
# its own .gitignore too (Composer vendor/, .env, storage/framework caches,
# bootstrap/cache, logs); these root-level entries are belt-and-suspenders so
# nothing generated under api/ is ever tracked from the repo root.
/api/vendor/
/api/node_modules/
/api/.env
/api/public/build/
/api/public/hot
/api/storage/*.key
/api/.phpunit.result.cache

# Laravel scaffold files this API-only project does NOT use — `composer
# create-project laravel/laravel` regenerates these, but they're dead weight
# here (no Blade/Vite frontend; GitHub ignores nested workflow dirs; StyleCI
# unused). Ignored so a future re-scaffold + `git add` can't re-track them.
/api/package.json
/api/package-lock.json
/api/vite.config.js
/api/.styleci.yml
/api/.npmrc
/api/.github/

# empty mount-point stub Docker creates when compose mounts the `vendor` volume
# into the ./app -> /var/www/html mount (docker-compose.yml); also the symlink
# tools/ensure-dev-stack.sh creates for native (Docker-less) web sessions. No
# trailing slash: unlike a directory-only pattern, this also matches the
# symlink, which `git status` would otherwise show as untracked.
/app/vendor

# runtime error log written by bootstrap.php on non-prod (dev/test/qa); a local
# artifact inside the deployed app/ tree — never commit it.
/app/php-error.log

# generated FTP deploy artifact (npm run build); never hand-edit or commit
/dist/build/

# generated per-env overlay files (npm run build:overlay); never hand-edit or commit
/dist/

# generated Vite build output (npm run build / vite build); never hand-edit or commit
/app/assets/dist/

# linter / tool caches
.php-cs-fixer.cache
.phpcs.cache
.phpunit.cache
.phpunit.result.cache

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
.idea/
