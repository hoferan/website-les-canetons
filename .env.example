# Deploy + migration settings for ONE environment, with uniform variable names.
#
# Copy this file once per environment you deploy to and rename the copy:
#   cp .env.example .env.test     # then fill in TEST's values
#   cp .env.example .env.qa       # then fill in QA's values
#   cp .env.example .env.prod     # then fill in PROD's values
#
# The copies are git-ignored. The tooling loads .env.<target> for the target you
# run (e.g. `npm run deploy:test` / `npm run dbmigrate:test` read .env.test),
# falling back to a shared `.env` for anything not set in the per-env file.
#
# In CI, these are GitHub Environment secrets (same names) on the test / qa /
# prod Environments — one FTP_DIR / SITE_URL / MIGRATE_TOKEN per environment.

# --- FTP (plain) -----------------------------------------------------------
# The one FTP account can reach every environment, so the deploy hard-refuses to
# run unless FTP_DIR's path matches the target env name (contains test/qa/prod).
FTP_HOST=CHANGE_ME
FTP_USER=CHANGE_ME
FTP_PASS=CHANGE_ME
# Remote docroot for THIS environment (relative to the FTP user's home — whatever
# your FTP client shows as the folder path). Must contain the env name.
FTP_DIR=CHANGE_ME
# Parallel upload connections (optional). Default 6, clamped 1-8. Higher =
# faster on many-file deploys (e.g. the Laravel vendor tree); set 1 to force
# the old serial upload if the host limits concurrent FTP connections.
FTP_CONCURRENCY=6

# --- Staging Basic Auth (TEST / QA only; leave blank on PROD) --------------
# ABSOLUTE server path to this env's .htpasswd. `npm run build:overlay <env>`
# injects it into the generated staging .htaccess (replacing __HTPASSWD_PATH__).
HTPASSWD_PATH=CHANGE_ME

# --- Server-side DB migrations ---------------------------------------------
# Must match `migrate.token` in THIS environment's server config.php. SITE_URL is
# the public base URL the migration trigger POSTs to (…/api/migrate).
MIGRATE_TOKEN=CHANGE_ME
SITE_URL=https://CHANGE_ME
# TEST/QA only: the site-wide HTTP Basic Auth credentials (same as .htpasswd), so
# the migration trigger can reach /api/migrate through Basic Auth. Leave BOTH
# blank on PROD (no Basic Auth there).
BASIC_AUTH_USER=CHANGE_ME
BASIC_AUTH_PASS=CHANGE_ME
