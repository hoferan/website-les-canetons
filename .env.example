# FTP deploy settings for the TEST staging server (used by `npm run deploy:test`).
# Copy to `.env` (git-ignored) and fill in the real values. Plain FTP.
#
# FTP_TEST_DIR is the remote path to the TEST site's docroot, relative to the FTP
# user's home. On easy-hebergement the site lives at the absolute server path
#   /var/www/sites/lescanetoqg/public_html/staging/test.lescanetons.org
# so via FTP it is typically /public_html/staging/test.lescanetons.org (adjust to
# whatever your FTP client shows as the folder path).

FTP_HOST=ftp.easy-hebergement.net
FTP_USER=
FTP_PASS=
FTP_TEST_DIR=/public_html/staging/test.lescanetons.org
